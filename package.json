{
	"name": "diggy",
	"version": "1.1.6",
	"description": "Multi-backend DNS resolver for Node.js/Browser — supports dig, DNS over HTTPS, and native Node.js DNS.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OzzyCzech/diggy.git"
	},
	"website": "https://ozzyczech.github.io/diggy/",
	"publishConfig": {
		"access": "public"
	},
	"author": "Roman Ožana <roman@ozana.cz>",
	"keywords": [
		"dns",
		"dig",
		"dns-over-https",
		"DoH",
		"nodejs",
		"browser",
		"dns-resolver",
		"resolver",
		"lookup",
		"dns-client",
		"dns-server",
		"dns-tools",
		"google-dns",
		"cloudflare-dns",
		"dns-over-tls",
		"js-dns"
	],
	"license": "MIT",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		"types": "./dist/index.d.ts",
		"default": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsc",
		"prepare": "npm run build",
		"test": "tsc --noEmit && vitest",
		"format": "biome check --write .",
		"format:check": "biome check .",
		"docs": "typedoc"
	},
	"resolutions": {
		"picomatch": "^4.0.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@ozzyczech/tsconfig": "^2.0.0",
		"@types/bun": "^1.3.12",
		"@types/deno": "^2.5.0",
		"@types/node": "^25.6.0",
		"tsx": "^4.21.0",
		"typedoc": "^0.28.19",
		"typescript": "^5.9.3",
		"vitest": "^4.1.4"
	}
}
